# =============================================================================
# .gitignore
# Urban Allergenic Tree Species Mapping — Enschede
# =============================================================================

# ── Large raw data (too large for GitHub, publicly available) ─────────────────
data/raw/lidar_tiles/
data/raw/rgb_tiles/
data/raw/cir_tiles/

# ── Large processed rasters ───────────────────────────────────────────────────
data/processed/lidar/

# ── YOLO image patch splits (thousands of .tif files) ────────────────────────
data/processed/splits_rgb/
data/processed/splits_irrg/
data/processed/splits_rgb_seg/
data/processed/splits_irrg_seg/

# ── Third-party data (access restricted or publicly available) ───────────────
data/external/municipal_gt/
data/external/crown_polygons_gt/
data/external/ut_campus_gt/

# ── YOLO model weights (too large for GitHub) ─────────────────────────────────
# Use the university archive for model weights:
# \\ad.utwente.nl\itc\Archive\CourseData\Upload\Herl_s3482170
models/yolov11_detection/rgb/weights/
models/yolov11_detection/irrg/weights/
models/yolov11_segmentation/rgb/weights/
models/yolov11_segmentation/irrg/weights/

# Keep metric files and plots inside model folders (small, useful for reference)
# models/yolov11_detection/rgb/results.csv  ← included
# models/yolov11_detection/rgb/*.png        ← included

# ── Python cache ──────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo

# ── Jupyter notebook checkpoints ─────────────────────────────────────────────
.ipynb_checkpoints/
*/.ipynb_checkpoints/

# ── OS and editor files ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini
*.swp
*.swo
.vscode/
.idea/

# ── Environment files ─────────────────────────────────────────────────────────
.env
*.egg-info/
dist/
build/

# ── Temporary files ───────────────────────────────────────────────────────────
*.tmp
*.log
